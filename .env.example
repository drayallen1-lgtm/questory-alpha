# Mapbox token (optional) — enables live Map view in Questory Alpha
# Get a free token at https://account.mapbox.com/
# On Vercel: Project → Settings → Environment Variables (redeploy after adding)
VITE_MAPBOX_TOKEN=

# Supabase (optional) — enables cloud auth and persistence
# Create a project at https://supabase.com and run supabase/migrations/001_questory_alpha.sql
# On Vercel: set both vars for Production, then redeploy so Vite inlines them at build time
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
